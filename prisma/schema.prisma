generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Categories (3-level tree) ────────────────────────────────────────────────

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String
  level     Int        // 1 = top, 2 = sub, 3 = leaf
  parentId  Int?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products    Product[]
  stockItems  StockItem[] @relation("StockItemCategory")
  createdAt   DateTime   @default(now())

  @@unique([name, parentId])
  @@index([parentId])
  @@index([level])
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          Int      @id             // source ID from donballon.ru
  name        String                   // Описание для анонса
  description String?                  // full HTML description
  price       Decimal  @db.Decimal(10, 2)
  salePrice   Decimal? @db.Decimal(10, 2)
  vatRate     String?

  imageUrl  String?
  images    String[] // additional product images (beyond the head imageUrl)
  videoUrl  String?

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  collection String?
  holidays   String[]  // e.g. ["Новый Год", "День Рождения"]

  model     String?
  material  String?
  shade     String?
  color     String?
  colorGroup String?
  sizeInches String?
  weight    String?

  minQuantity     Int  @default(1)
  unitsPerPackage Int?
  unitsPerBox     Int?

  barcode         String?
  manufacturer    String?
  countryOfOrigin String?

  isActive            Boolean   @default(true)
  expectedRestockDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([colorGroup])
  @@index([isActive])
  @@index([price])
  @@index([manufacturer])
  @@index([salePrice])
}

// ─── Sharmaster warehouse stock ───────────────────────────────────────────────

model StockItem {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  fullName   String?
  article    String?
  barcode    String?
  brand      String?
  stock      Int      @default(0)
  pricePerPc Decimal  @db.Decimal(10, 2)
  imageUrl   String?
  images     String[]
  productId  Int?
  onSale     Boolean  @default(false)

  categoryId Int?
  category   Category? @relation("StockItemCategory", fields: [categoryId], references: [id])

  updatedAt  DateTime @updatedAt

  @@index([stock])
  @@index([brand])
  @@index([pricePerPc])
  @@index([article])
  @@index([categoryId])
  @@index([onSale])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  password  String   // bcrypt hash — never stored in plaintext
  createdAt DateTime @default(now())
  orders    Order[]
  sessions  Session[]

  @@index([email])
}

// Server-side session record. The JWT's `jti` claim references the id here —
// deleting the row revokes the token immediately, before its signature expires.
model Session {
  id        String   @id
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id           Int         @id @default(autoincrement())
  userId       Int?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName String
  phone        String
  address      String
  total        Decimal     @db.Decimal(10, 2)
  status       String      @default("Принят")
  createdAt    DateTime    @default(now())
  items        OrderItem[]

  @@index([userId])
  @@index([phone])
  @@index([createdAt])
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stockItemId Int?
  name        String
  qty         Int
  price       Decimal @db.Decimal(10, 2)

  @@index([orderId])
}
